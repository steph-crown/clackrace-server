PORT=4000
HOST=0.0.0.0
DATABASE_URL=postgres://clackrace:clackrace@localhost:5433/clackrace
REDIS_URL=redis://localhost:6379

# Comma-separated extra origins (localhost:3000 always included)
CORS_ORIGIN=http://localhost:3000

# Auth — public URL is the Next app; /api/auth is proxied there
BETTER_AUTH_SECRET=dev-only-clackrace-auth-secret-change-me
BETTER_AUTH_URL=http://localhost:3000
# Alias accepted by the server (optional)
# AUTH_URL=http://localhost:3000

# Optional challenge invite email (Resend free tier).
# Without RESEND_API_KEY the server logs the accept URL instead — fine for local/dev.
# Sign up at https://resend.com → API Keys → paste here.
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM=ClackRace <onboarding@resend.dev>

# Sole admin for /nimad (seeded on every boot). Password min 8 chars.
# ADMIN_USERNAME=nimad
# ADMIN_PASSWORD=change-me-now
# ADMIN_EMAIL=nimad@example.com

# Optional legacy — shadow-hold review via token (GET /admin/shadow-holds)
# Prefer signing in as admin at /nimad instead.
# ADMIN_TOKEN=dev-admin-token
